  escrow_id           Int?
  reason              String               @db.VarChar(30)
  description         String
  evidence_urls       Json?
  status              String?              @default("open") @db.VarChar(20)
  resolution_notes    String?
  refund_amount       Decimal?             @db.Decimal(10, 2)
  resolved_by         Int?
  resolved_at         DateTime?            @db.Timestamp(6)
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @db.Timestamp(6)
  dispute_messages    dispute_messages[]
  customers           customers            @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  escrow_transactions escrow_transactions? @relation(fields: [escrow_id], references: [id], onUpdate: NoAction)
  orders              orders               @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sellers             sellers              @relation(fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([customer_id], map: "idx_disputes_customer")
  @@index([seller_id], map: "idx_disputes_seller")
  @@index([status], map: "idx_disputes_status")
}

