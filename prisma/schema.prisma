generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admin_sessions {
  id            Int         @id @default(autoincrement())
  admin_user_id Int
  session_token String      @unique @db.VarChar(255)
  expires_at    DateTime    @db.Timestamp(6)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  admin_users   admin_users @relation(fields: [admin_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model admin_users {
  id                Int              @id @default(autoincrement())
  username          String           @unique @db.VarChar(50)
  email             String           @unique @db.VarChar(100)
  password_hash     String           @db.VarChar(255)
  role              String           @default("content_admin") @db.VarChar(20)
  permissions       Json?
  is_active         Boolean?         @default(true)
  last_login        DateTime?        @db.Timestamp(6)
  created_by        Int?
  created_at        DateTime?        @default(now()) @db.Timestamp(6)
  updated_at        DateTime?        @default(now()) @db.Timestamp(6)
  admin_sessions    admin_sessions[]
  admin_users       admin_users?     @relation("admin_usersToadmin_users", fields: [created_by], references: [id], onUpdate: NoAction)
  other_admin_users admin_users[]    @relation("admin_usersToadmin_users")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model analytics {
  id          Int         @id @default(autoincrement())
  event_type  String      @db.VarChar(20)
  product_id  Int?
  category_id Int?
  user_ip     String?     @db.VarChar(45)
  user_agent  String?
  referrer    String?     @db.VarChar(500)
  page_url    String?     @db.VarChar(500)
  metadata    Json?
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  categories  categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  products    products?   @relation(fields: [product_id], references: [id], onUpdate: NoAction)
}

model analytics_settings {
  id                           Int       @id @default(autoincrement())
  google_analytics_enabled     Boolean?  @default(false)
  google_analytics_tracking_id String?   @db.VarChar(50)
  matomo_enabled               Boolean?  @default(false)
  matomo_url                   String?   @db.VarChar(500)
  matomo_site_id               String?   @db.VarChar(10)
  custom_events_config         Json?
  privacy_settings             Json?
  created_at                   DateTime? @default(now()) @db.Timestamp(6)
  updated_at                   DateTime? @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model banner_ads {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?
  image_url   String     @db.VarChar(500)
  link_url    String?    @db.VarChar(1000)
  position    String?    @default("top") @db.VarChar(10)
  is_active   Boolean?   @default(true)
  start_date  DateTime?  @db.Date
  end_date    DateTime?  @db.Date
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @default(now()) @db.Timestamp(6)
  payments    payments[]
}

model brands {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?
  logo_url    String?    @db.VarChar(500)
  website_url String?    @db.VarChar(500)
  is_active   Boolean?   @default(true)
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @default(now()) @db.Timestamp(6)
  products    products[]
}

model categories {
  id               Int           @id @default(autoincrement())
  name             String        @db.VarChar(255)
  slug             String        @unique @db.VarChar(255)
  description      String?
  image_url        String?       @db.VarChar(500)
  parent_id        Int?
  sort_order       Int?          @default(0)
  is_active        Boolean?      @default(true)
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  updated_at       DateTime?     @default(now()) @db.Timestamp(6)
  show_in_menu     Boolean?      @default(true)
  menu_order       Int?          @default(0)
  analytics        analytics[]
  categories       categories?   @relation("categoriesTocategories", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_categories categories[]  @relation("categoriesTocategories")
  category_seo     category_seo?
  products         products[]
}

model category_seo {
  id                  Int        @id @default(autoincrement())
  category_id         Int        @unique
  meta_title          String?    @db.VarChar(255)
  meta_description    String?
  meta_keywords       String?
  og_title            String?    @db.VarChar(255)
  og_description      String?
  og_image            String?    @db.VarChar(500)
  twitter_title       String?    @db.VarChar(255)
  twitter_description String?
  twitter_image       String?    @db.VarChar(500)
  no_index            Boolean?   @default(false)
  no_follow           Boolean?   @default(false)
  created_at          DateTime?  @default(now()) @db.Timestamp(6)
  updated_at          DateTime?  @default(now()) @db.Timestamp(6)
  categories          categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
