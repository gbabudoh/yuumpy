/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customer_notifications {
  id           Int       @id @default(autoincrement())
  customer_id  Int
  type         String?   @default("system") @db.VarChar(10)
  title        String    @db.VarChar(255)
  message      String
  link_url     String?   @db.VarChar(500)
  is_read      Boolean?  @default(false)
  order_id     Int?
  order_number String?   @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  customers    customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders       orders?   @relation(fields: [order_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_notifications_created_at")
  @@index([customer_id], map: "idx_notifications_customer_id")
  @@index([is_read], map: "idx_notifications_is_read")
  @@index([order_id], map: "idx_notifications_order_id")
}

model customer_rewards {
  id                       Int       @id @default(autoincrement())
  customer_id              Int       @unique
  points_balance           Int?      @default(0)
  lifetime_points_earned   Int?      @default(0)
  lifetime_points_redeemed Int?      @default(0)
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  updated_at               DateTime? @default(now()) @db.Timestamp(6)
  customers                customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model customer_sessions {
  id          Int       @id @default(autoincrement())
  customer_id Int
  token       String    @db.VarChar(500)
  expires_at  DateTime  @db.Timestamp(6)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_customer_sessions_token")
}

model customers {
  id                     Int                      @id @default(autoincrement())
  email                  String                   @unique @db.VarChar(255)
  password_hash          String?                  @db.VarChar(255)
  first_name             String                   @db.VarChar(100)
  last_name              String                   @db.VarChar(100)
  phone                  String?                  @db.VarChar(20)
  is_active              Boolean?                 @default(true)
  email_verified         Boolean?                 @default(false)
  google_id              String?                  @unique @db.VarChar(255)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  customer_addresses     customer_addresses[]
  customer_notifications customer_notifications[]
  customer_rewards       customer_rewards?
  customer_sessions      customer_sessions[]
  disputes               disputes[]
  orders                 orders[]
  rewards_history        rewards_history[]
  seller_reviews         seller_reviews[]
  wishlist               wishlist[]

  @@index([email], map: "idx_customers_email")
}

